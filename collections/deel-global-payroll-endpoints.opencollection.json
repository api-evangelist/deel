                "type": "path",
                "description": "Unique identifier of the shift to retrieve."
              }
            ]
          },
          "docs": "Retrieve details of a specific shift by external ID.\n **Token scopes**: `time-tracking:read`"
        },
        {
          "info": {
            "name": "Update a shift",
            "type": "http"
          },
          "http": {
