          "http": {
            "method": "DELETE",
            "url": "https://api.letsdeel.com/rest/v2/time_tracking/shifts/:external_id",
            "headers": [
              {
                "name": "Authorization",
                "value": ""
              }
            ],
            "params": [
              {
                "name": "external_id",
                "value": "",
                "type": "path",
                "description": "The unique external identifier of the shift to be deleted."
              }
